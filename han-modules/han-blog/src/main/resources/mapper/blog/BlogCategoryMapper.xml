<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.han.blog.mapper.BlogCategoryMapper">

    <!-- 统计别名数量（包含逻辑删除数据） -->
    <select id="selectSlugCount" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM blog_category
        WHERE slug = #{slug}
        <if test="excludeCategoryId != null">
            AND category_id != #{excludeCategoryId}
        </if>
    </select>

</mapper>

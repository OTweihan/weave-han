<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.han.blog.mapper.BlogPostMapper">

    <resultMap id="BlogPostVoResult" type="com.han.blog.domain.vo.BlogPostVo">
        <id property="postId" column="post_id"/>
        <result property="title" column="title"/>
        <result property="slug" column="slug"/>
        <result property="summary" column="summary"/>
        <result property="coverImage" column="cover_image"/>
        <result property="authorId" column="author_id"/>
        <result property="categoryId" column="category_id"/>
        <result property="status" column="status"/>
        <result property="isTop" column="is_top"/>
        <result property="isFeatured" column="is_featured"/>
        <result property="allowComment" column="allow_comment"/>
        <result property="createTime" column="create_time"/>
        <result property="publishedTime" column="published_time"/>
        <association property="category" javaType="com.han.blog.domain.vo.BlogCategoryVo">
            <id property="categoryId" column="c_category_id"/>
            <result property="name" column="c_name"/>
            <result property="slug" column="c_slug"/>
        </association>
    </resultMap>

    <select id="selectPagePostList" resultMap="BlogPostVoResult">
        SELECT
            p.post_id, p.title, p.slug, p.summary, p.cover_image, p.author_id, p.category_id,
            p.status, p.is_top, p.is_featured, p.allow_comment, p.create_time, p.published_time,
            c.category_id as c_category_id,
            c.name as c_name,
            c.slug as c_slug
        FROM blog_post p
        LEFT JOIN blog_category c ON p.category_id = c.category_id
        ${ew.customSqlSegment}
    </select>
</mapper>
